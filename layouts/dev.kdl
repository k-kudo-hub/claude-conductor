layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    tab name="Dev" focus=true {
        pane split_direction="vertical" {
            pane {
                name "Claude Code"
                command "claude"
                size "50%"
            }
            pane {
                name "Preview"
                command "nvim"
                size "50%"
            }
        }
    }

    tab name="Git" {
        pane {
            name "lazygit"
            command "lazygit"
            start_suspended true
        }
    }

    tab name="Shell" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
