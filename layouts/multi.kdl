layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    // Main tab: Dashboard + Control terminal
    tab name="Main" focus=true {
        pane split_direction="horizontal" {
            pane size="70%" {
                name "Dashboard"
                command "bash"
                args "-c" "$HOME/.claude-conductor/scripts/dashboard-loop.sh"
            }
            pane size="30%" {
                name "Control"
                focus true
            }
        }
    }
}
