layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    // Main tab: Current Tasks (left-top) + Done Tasks (left-bottom) + News (right-top) + Task Creator (right-bottom)
    tab name="Main" focus=true {
        pane split_direction="horizontal" {
            pane size="70%" split_direction="vertical" {
                pane size="60%" {
                    name "Dashboard"
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/dashboard-loop.sh"
                }
                pane size="40%" {
                    name "Done"
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/done-loop.sh"
                }
            }
            pane size="30%" split_direction="vertical" {
                pane size="40%" {
                    name "News"
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/news-loop.sh"
                }
                pane size="60%" {
                    name "TaskCreate"
                    focus true
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/task-create-loop.sh"
                }
            }
        }
    }
}
