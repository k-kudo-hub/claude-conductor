layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }

    // Main tab: Dashboard (left) + Done (center) + News (right) + Task Creator (bottom)
    tab name="Main" focus=true {
        pane split_direction="horizontal" {
            pane size="70%" split_direction="vertical" {
                pane size="40%" {
                    name "Dashboard"
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/dashboard-loop.sh"
                }
                pane size="30%" {
                    name "Done"
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/done-loop.sh"
                }
                pane size="30%" {
                    name "News"
                    command "bash"
                    args "-c" "$HOME/.claude-conductor/scripts/news-loop.sh"
                }
            }
            pane size="30%" {
                name "TaskCreate"
                focus true
                command "bash"
                args "-c" "$HOME/.claude-conductor/scripts/task-create-loop.sh"
            }
        }
    }
}
